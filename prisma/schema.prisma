// prisma/schema.prisma — fuente de verdad del modelo de datos
// Prisma v7: la URL de DB se configura en prisma.config.ts (no en este archivo)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Perfil ──────────────────────────────────────────────────────────────────
model Perfil {
  id        String   @id @db.Uuid @map("id")
  nombre    String   @map("nombre")
  email     String   @map("email")
  // rol válidos: "dueno" | "empleado"
  rol       String   @default("empleado") @map("rol")
  activo    Boolean  @default(true) @map("activo")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("perfiles")
}

// ─── Cliente ─────────────────────────────────────────────────────────────────
model Cliente {
  id        String   @id @default(uuid()) @db.Uuid @map("id")
  nombre    String   @map("nombre")
  apellido  String?  @map("apellido")
  telefono  String?  @map("telefono")
  email     String?  @map("email")
  notas     String?  @db.Text @map("notas")
  activo    Boolean  @default(true) @map("activo")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  citas  Cita[]
  ventas Venta[]

  @@map("clientes")
}

// ─── Servicio ─────────────────────────────────────────────────────────────────
model Servicio {
  id              String   @id @default(uuid()) @db.Uuid @map("id")
  nombre          String   @map("nombre")
  descripcion     String?  @db.Text @map("descripcion")
  precio          Decimal  @db.Decimal(10, 2) @map("precio")
  costo           Decimal? @db.Decimal(10, 2) @map("costo")
  duracionMinutos Int      @map("duracion_minutos")
  categoria       String?  @map("categoria")
  activo          Boolean  @default(true) @map("activo")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  citas Cita[]

  @@map("servicios")
}

// ─── Cita ─────────────────────────────────────────────────────────────────────
model Cita {
  id         String    @id @default(uuid()) @db.Uuid @map("id")
  clienteId  String    @db.Uuid @map("cliente_id")
  servicioId String    @db.Uuid @map("servicio_id")
  ventaId    String?   @unique @db.Uuid @map("venta_id")
  fecha      DateTime  @db.Date @map("fecha")
  horaInicio DateTime  @db.Time(6) @map("hora_inicio")
  horaFin    DateTime? @db.Time(6) @map("hora_fin")
  // estado válidos: "pendiente" | "confirmada" | "realizada" | "cancelada" | "no_asistio"
  estado     String    @default("pendiente") @map("estado")
  notas      String?   @db.Text @map("notas")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  cliente  Cliente  @relation(fields: [clienteId], references: [id])
  servicio Servicio @relation(fields: [servicioId], references: [id])
  venta    Venta?   @relation("CitaVenta", fields: [ventaId], references: [id])
  ventaRef Venta?   @relation("VentaCita")

  @@map("citas")
}

// ─── Venta ───────────────────────────────────────────────────────────────────
model Venta {
  id             String   @id @default(uuid()) @db.Uuid @map("id")
  clienteId      String   @db.Uuid @map("cliente_id")
  citaId         String?  @unique @db.Uuid @map("cita_id")
  inventarioId   String?  @db.Uuid @map("inventario_id")
  // tipo válidos: "servicio" | "producto"
  tipo           String   @default("servicio") @map("tipo")
  // concepto: nombre del servicio o producto vendido
  concepto       String?  @map("concepto")
  cantidad       Int      @default(1) @map("cantidad")
  precioUnitario Decimal? @db.Decimal(10, 2) @map("precio_unitario")
  costoUnitario  Decimal? @db.Decimal(10, 2) @map("costo_unitario")
  subtotal       Decimal  @db.Decimal(10, 2) @map("subtotal")
  descuento      Decimal  @db.Decimal(10, 2) @default(0) @map("descuento")
  total          Decimal  @db.Decimal(10, 2) @map("total")
  // metodo_pago válidos: "efectivo" | "tarjeta" | "transferencia" | "otro"
  metodoPago     String   @map("metodo_pago")
  fecha          DateTime @db.Date @map("fecha")
  notas          String?  @db.Text @map("notas")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  cliente    Cliente     @relation(fields: [clienteId], references: [id])
  inventario Inventario? @relation(fields: [inventarioId], references: [id])
  cita       Cita?       @relation("VentaCita", fields: [citaId], references: [id])
  citaRef    Cita?       @relation("CitaVenta")

  @@map("ventas")
}

// ─── Gasto ───────────────────────────────────────────────────────────────────
model Gasto {
  id          String   @id @default(uuid()) @db.Uuid @map("id")
  concepto    String   @map("concepto")
  monto       Decimal  @db.Decimal(10, 2) @map("monto")
  // categoria válidas: ver CATEGORIAS_GASTO en src/lib/constants.ts
  categoria   String   @map("categoria")
  fecha       DateTime @db.Date @map("fecha")
  comprobante String?  @map("comprobante")
  notas       String?  @db.Text @map("notas")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("gastos")
}

// ─── Inventario ───────────────────────────────────────────────────────────────
model Inventario {
  id             String   @id @default(uuid()) @db.Uuid @map("id")
  codigo         String?  @map("codigo")                         // SKU o código de barras
  nombre         String   @map("nombre")
  descripcion    String?  @db.Text @map("descripcion")
  // categoria válidas: ver CATEGORIAS_INVENTARIO en src/lib/constants.ts
  categoria      String   @map("categoria")
  // unidad válidas: "pieza" | "litro" | "mililitro" | "gramo" | "kilogramo"
  unidad         String   @default("pieza") @map("unidad")
  stockActual    Decimal  @db.Decimal(10, 2) @map("stock_actual")
  stockMinimo    Decimal  @db.Decimal(10, 2) @default(0) @map("stock_minimo")
  precioUnitario Decimal  @db.Decimal(10, 2) @map("precio_unitario") // costo de compra
  precioVenta    Decimal? @db.Decimal(10, 2) @map("precio_venta")    // precio al público
  activo         Boolean  @default(true) @map("activo")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  compras Compra[]
  ventas  Venta[]

  @@map("inventario")
}

// ─── Compra ───────────────────────────────────────────────────────────────────
model Compra {
  id             String   @id @default(uuid()) @db.Uuid @map("id")
  productoId     String   @db.Uuid @map("producto_id")
  cantidad       Decimal  @db.Decimal(10, 2) @map("cantidad")
  precioUnitario Decimal  @db.Decimal(10, 2) @map("precio_unitario")
  total          Decimal  @db.Decimal(10, 2) @map("total")
  proveedor      String?  @map("proveedor")
  fecha          DateTime @db.Date @map("fecha")
  notas          String?  @db.Text @map("notas")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  producto Inventario @relation(fields: [productoId], references: [id])

  @@map("compras")
}

// ─── Configuracion ────────────────────────────────────────────────────────────
model Configuracion {
  id           String    @id @default(uuid()) @db.Uuid @map("id")
  nombreSalon  String    @map("nombre_salon")
  telefono     String?   @map("telefono")
  email        String?   @map("email")
  direccion    String?   @db.Text @map("direccion")
  moneda       String    @default("MXN") @map("moneda")
  zonaHoraria  String    @default("America/Mexico_City") @map("zona_horaria")
  horaApertura DateTime? @db.Time(6) @map("hora_apertura")
  horaCierre   DateTime? @db.Time(6) @map("hora_cierre")
  logoUrl      String?   @map("logo_url")
  anioFiscal   Int?      @map("anio_fiscal")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("configuracion")
}
